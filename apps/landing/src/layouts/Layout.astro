---
import '@tastify/react/styles.css';
import '../styles/landing.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <title>Tastify – Showcase your music taste, easily</title>
    <meta
      name="description"
      content="A complete set of dev tools to connect your personal site to Spotify and display your listening habits with beautiful components."
    />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://tastify.dev/" />
    <meta property="og:title" content="Tastify – Showcase your music taste, easily" />
    <meta
      property="og:description"
      content="A complete set of dev tools to connect your personal site to Spotify and display your listening habits with beautiful components."
    />
    <meta property="og:image" content="https://tastify.dev/og.jpg" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="2400" />
    <meta property="og:image:height" content="1260" />
    <meta property="og:image:alt" content="Tastify – Showcase your music taste, easily" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://tastify.dev/" />
    <meta name="twitter:title" content="Tastify – Showcase your music taste, easily" />
    <meta
      name="twitter:description"
      content="A complete set of dev tools to connect your personal site to Spotify and display your listening habits with beautiful components."
    />
    <meta name="twitter:image" content="https://tastify.dev/og.jpg" />
    <meta name="twitter:image:alt" content="Tastify – Showcase your music taste, easily" />

    <link
      href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700,800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

---

<section class="hero">
  <div class="container">
    <div class="hero__logo">
      <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="64" height="64" rx="14.2222" fill="url(#paint0_linear_14_7)"/>
        <circle cx="32" cy="32" r="21.3333" fill="#FEFEFE" fill-opacity="0.5"/>
        <circle cx="32" cy="32" r="16" fill="#FEFEFE" fill-opacity="0.5"/>
        <circle cx="32" cy="32" r="10.6667" fill="#FEFEFE" fill-opacity="0.8"/>
        <defs>
        <linearGradient id="paint0_linear_14_7" x1="-8" y1="-4.44444" x2="54.2222" y2="77.3333" gradientUnits="userSpaceOnUse">
        <stop stop-color="#C0F5C4"/>
        <stop offset="1" stop-color="#59BA8D"/>
        </linearGradient>
        </defs>
      </svg>
        
    </div>

    <h1 class="hero__heading">
      Showcase your<br />music taste, easily
    </h1>

    <p class="hero__description">
      Tastify provides a complete set of dev tools to connect your personal site to a spotify account and display your listening habits.
    </p>

    <div class="hero__actions">
      <a href="#get-started" class="btn btn--primary">Get started</a>
      <a
        href="https://github.com/crisog/tastify"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn--secondary"
      >
        View docs
      </a>
    </div>
  </div>
</section>

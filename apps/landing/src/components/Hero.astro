<section class="hero">
  <div class="container">
    <div class="hero__logo">
      <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="16" cy="16" r="12" stroke="white" stroke-width="2" fill="none" />
        <circle cx="16" cy="16" r="5" fill="white" />
      </svg>
    </div>

    <h1 class="hero__heading">
      Showcase your<br />music taste, easily
    </h1>

    <p class="hero__description">
      Tastify provides a complete set of dev tools to connect your personal site to a spotify account and display your listening habits.
    </p>

    <div class="hero__actions">
      <a href="#get-started" class="btn btn--primary">Get started</a>
      <a
        href="https://github.com/crisog/tastify"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn--secondary"
      >
        View docs
      </a>
    </div>
  </div>
</section>
